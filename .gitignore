# Python env (1.6 GB, Windows-built; regenerate with: pip install -r requirements.txt)
venv/
__pycache__/
*.pyc

# LaTeX build artifacts
build/_prev/
build/*.pdf
*.aux
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz
*.nav
*.snm
*.toc

# QA / extraction scratch (regenerable)
.verify_scratch/
sources/converted/

# PPTX export output (PPT Master prepare/export — regenerable from sources).
# The skill itself lives in tracked skills/ppt-master/; only the build output is ignored.
build/pptx/

# Scratch crops / temp images at repo or build root
/_*.png
build/_*.png
/tmp_*

# Secrets — never commit API keys
.env
.env.*

# Local agent / tooling state
.claude/
.python-version

# OS noise
.DS_Store
Thumbs.db

# Large build payloads (hundreds of MB — never belong in git)
poster_payload*.zip

# Draft / archived posters (build/maintenance.py output; regenerable from build).
# PDFs and previews are always ignored; auto-archived .tex snapshots
# (poster_<NNN>_<datetime>.tex) are too — force-add a curated final with `git add -f`.
build/drafts/*.pdf
build/drafts/_prev/
build/drafts/poster_*_*.tex

# Convenience symlinks so draft builds resolve assets/ and logos/ from build/drafts/
build/drafts/assets
build/drafts/logos
